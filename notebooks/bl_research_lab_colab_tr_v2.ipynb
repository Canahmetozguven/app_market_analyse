    "CONFIG = {\n",
    "    # Türkiye odaklı ve Yahoo Finance'ta genelde daha sağlam veri veren semboller\n",
    "    \"tickers\": [\"THYAO.IS\", \"AKBNK.IS\", \"EREGL.IS\", \"ZGOLD.IS\", \"USDTRY=X\"],\n",
    "    \"ticker_labels\": {\n",
    "        \"THYAO.IS\": \"THYAO\",\n",
    "        \"AKBNK.IS\": \"AKBNK\",\n",
    "        \"EREGL.IS\": \"EREGL\",\n",
    "        \"ZGOLD.IS\": \"Altın BYF\",\n",
    "        \"USDTRY=X\": \"Dolar/TL\",\n",
    "    },\n",
    "    \"salary_amount_try\": 25000,\n",
    "    \"target_test_months\": 6,\n",
    "    \"target_lookback_days\": 252,   # 1 yıl civarı lookback; önceki sürümde çok agresifti\n",
    "    \"download_period\": \"10y\",\n",
    "    \"risk_free_rate\": 0.0,\n",
    "    \"max_weight\": 0.70,\n",
    "    \"gold_label\": \"Altın BYF\",\n",
    "    \"gold_min\": 0.10,\n",
    "    \"gold_max\": 0.55,\n",
    "    \"min_assets_required\": 3,\n",
    "}\n",
    "CONFIG\n"
   ]
