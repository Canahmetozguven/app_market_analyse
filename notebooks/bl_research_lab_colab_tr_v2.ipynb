    "## Drawdown Grafiği\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "3bd511c3",
   "metadata": {},
   "outputs": [],
   "source": [
    "dd_parts = []\n",
    "for s in strategies:\n",
    "    sub = hist_df[hist_df[\"strategy\"] == s].sort_values(\"date\").copy()\n",
    "    sub[\"drawdown\"] = sub[\"portfolio_value\"] / sub[\"portfolio_value\"].cummax() - 1\n",
    "    dd_parts.append(sub[[\"date\", \"strategy\", \"drawdown\"]])\n",
    "\n",
