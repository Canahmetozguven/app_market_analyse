    "## Pseudo-Live Maaş Testi\n",
    "\n",
    "Her ay başında sabit maaş katkısı eklenir ve yalnızca o tarihe kadar görülen veriyle ağırlıklar belirlenir.\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "e4696c19",
   "metadata": {},
   "outputs": [],
   "source": [
    "strategies = [\"Eşit Ağırlık\", \"HRP\", \"Black-Litterman\"]\n",
    "\n",
    "hist_parts = []\n",
    "weight_parts = []\n",
    "diag_parts = []\n",
    "\n",
    "for s in strategies:\n",
    "    h, w, d = run_salary_backtest(prices, s)\n",
    "    hist_parts.append(h)\n",
    "    weight_parts.append(w)\n",
    "    if not d.empty:\n",
    "        diag_parts.append(d)\n",
    "\n",
    "hist_df = pd.concat(hist_parts, ignore_index=True)\n",
    "weights_df = pd.concat(weight_parts, ignore_index=True)\n",
    "bl_diag_df = pd.concat(diag_parts, ignore_index=True) if diag_parts else pd.DataFrame()\n",
    "\n",
    "display(hist_df.tail())\n"
   ]
