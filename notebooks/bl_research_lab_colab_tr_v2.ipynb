    "def download_one_ticker(ticker, period=\"10y\"):\n",
    "    data = yf.download(ticker, period=period, auto_adjust=True, progress=False)\n",
    "    if data is None or len(data) == 0:\n",
    "        return None\n",
    "    if isinstance(data.columns, pd.MultiIndex):\n",
    "        if (\"Close\", ticker) in data.columns:\n",
    "            s = data[(\"Close\", ticker)].copy()\n",
    "        else:\n",
    "            s = data[\"Close\"].copy()\n",
    "    else:\n",
    "        s = data[\"Close\"].copy()\n",
    "    s = pd.Series(s).dropna()\n",
    "    s.name = ticker\n",
    "    return s\n",
    "\n",
    "series_list = []\n",
    "coverage_rows = []\n",
    "\n",
    "for ticker in CONFIG[\"tickers\"]:\n",
    "    s = download_one_ticker(ticker, period=CONFIG[\"download_period\"])\n",
    "    n = 0 if s is None else len(s)\n",
    "    start = None if s is None or len(s) == 0 else str(s.index.min().date())\n",
    "    end = None if s is None or len(s) == 0 else str(s.index.max().date())\n",
    "    coverage_rows.append({\n",
    "        \"Ticker\": ticker,\n",
    "        \"Etiket\": CONFIG[\"ticker_labels\"].get(ticker, ticker),\n",
    "        \"Gözlem Sayısı\": n,\n",
    "        \"İlk Tarih\": start,\n",
    "        \"Son Tarih\": end,\n",
    "        \"Durum\": \"OK\" if n > 0 else \"Veri Yok\",\n",
    "    })\n",
    "    if s is not None and len(s) > 0:\n",
    "        s.name = CONFIG[\"ticker_labels\"].get(ticker, ticker)\n",
    "        series_list.append(s)\n",
    "\n",
    "coverage = pd.DataFrame(coverage_rows)\n",
    "display(coverage)\n",
    "\n",
    "if len(series_list) == 0:\n",
    "    raise ValueError(\"Hiçbir ticker için veri indirilemedi.\")\n",
    "\n",
    "prices = pd.concat(series_list, axis=1).sort_index()\n",
    "prices = prices.ffill()\n",
    "\n",
    "# Çok eksik kolonları at\n",
    "min_non_null = int(len(prices) * 0.60)\n",
    "keep_cols = [c for c in prices.columns if prices[c].notna().sum() >= min_non_null]\n",
    "prices = prices[keep_cols]\n",
    "\n",
    "# Kesişim yerine daha dayanıklı şekilde geç dönemden başlat\n",
    "first_valid_dates = prices.apply(lambda s: s.first_valid_index())\n",
    "common_start = first_valid_dates.max()\n",
    "prices = prices.loc[common_start:].dropna()\n",
    "\n",
    "if prices.shape[1] < CONFIG[\"min_assets_required\"]:\n",
    "    raise ValueError(f\"Yeterli aktif varlık yok. Kalan varlık sayısı: {prices.shape[1]}\")\n",
    "\n",
    "available_days = len(prices)\n",
    "effective_lookback_days = min(CONFIG[\"target_lookback_days\"], max(60, available_days - 40))\n",
    "\n",
    "monthly_points = prices.resample(\"MS\").first().dropna()\n",
    "if len(monthly_points) < 4:\n",
    "    raise ValueError(\"Aylık test için yeterli veri yok.\")\n",
    "\n",
    "effective_test_months = min(CONFIG[\"target_test_months\"], max(3, len(monthly_points) - 1))\n",
    "\n",
    "print(\"Kullanılan varlıklar:\", list(prices.columns))\n",
    "print(\"Toplam günlük gözlem:\", len(prices))\n",
    "print(\"Efektif lookback_days:\", effective_lookback_days)\n",
    "print(\"Efektif test_months:\", effective_test_months)\n",
    "\n",
    "display(prices.tail())\n"
   ]
  },
