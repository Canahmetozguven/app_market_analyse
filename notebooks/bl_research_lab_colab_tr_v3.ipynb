{"cells": [{"cell_type": "markdown", "id": "c0bda83c", "metadata": {}, "source": ["# T\u00fcrkiye Odakl\u0131 Maa\u015fla Yat\u0131r\u0131m Ara\u015ft\u0131rma Defteri \u2014 v3\n", "\n", "Bu s\u00fcr\u00fcm \u00f6nceki dosyadaki bozuk JSON sorununu d\u00fczeltmek i\u00e7in **programatik olarak** \u00fcretildi.\n", "\n", "Ama\u00e7:\n", "> Son 6 ay boyunca her ay maa\u015f\u0131mdan yat\u0131r\u0131m yapsayd\u0131m, T\u00fcrkiye odakl\u0131 bir evrende farkl\u0131 stratejiler nas\u0131l davran\u0131rd\u0131?\n", "\n", "\u00d6zellikler:\n", "- LLM yok\n", "- Dosya kayd\u0131 yok\n", "- Plotly grafikler\n", "- TL bi\u00e7imlendirme\n", "- Tek tek ticker indirme ve veri kapsam\u0131 kontrol\u00fc\n", "- Yetersiz veri varsa otomatik daha k\u0131sa lookback kullan\u0131m\u0131"]}, {"cell_type": "code", "execution_count": null, "id": "5b6fc676", "metadata": {}, "outputs": [], "source": ["# Colab kurulum h\u00fccresi\n", "!pip -q install yfinance PyPortfolioOpt plotly pandas numpy scipy scikit-learn"]}, {"cell_type": "code", "execution_count": null, "id": "fc52253d", "metadata": {}, "outputs": [], "source": ["import warnings\n", "warnings.filterwarnings(\"ignore\")\n", "\n", "import numpy as np\n", "import pandas as pd\n", "import yfinance as yf\n", "import plotly.express as px\n", "import plotly.graph_objects as go\n", "\n", "from pypfopt.risk_models import CovarianceShrinkage\n", "from pypfopt.hierarchical_portfolio import HRPOpt\n", "from pypfopt.black_litterman import BlackLittermanModel\n", "from pypfopt.efficient_frontier import EfficientFrontier"]}, {"cell_type": "code", "execution_count": null, "id": "f6288898", "metadata": {}, "outputs": [], "source": ["CONFIG = {\n", "    # Yahoo Finance'ta genelde daha sa\u011flam veri veren T\u00fcrkiye odakl\u0131 semboller\n", "    \"tickers\": [\"THYAO.IS\", \"AKBNK.IS\", \"EREGL.IS\", \"ZGOLD.IS\", \"USDTRY=X\"],\n", "    \"ticker_labels\": {\n", "        \"THYAO.IS\": \"THYAO\",\n", "        \"AKBNK.IS\": \"AKBNK\",\n", "        \"EREGL.IS\": \"EREGL\",\n", "        \"ZGOLD.IS\": \"Alt\u0131n BYF\",\n", "        \"USDTRY=X\": \"Dolar/TL\",\n", "    },\n", "    \"salary_amount_try\": 25000,\n", "    \"target_test_months\": 6,\n", "    \"target_lookback_days\": 252,\n", "    \"download_period\": \"10y\",\n", "    \"risk_free_rate\": 0.0,\n", "    \"max_weight\": 0.70,\n", "    \"gold_label\": \"Alt\u0131n BYF\",\n", "    \"gold_min\": 0.10,\n", "    \"gold_max\": 0.55,\n", "    \"min_assets_required\": 3,\n", "}\n", "CONFIG"]}, {"cell_type": "code", "execution_count": null, "id": "37de0b6f", "metadata": {}, "outputs": [], "source": ["def try_fmt(x):\n", "    if pd.isna(x):\n", "        return \"-\"\n", "    return f\"\u20ba{x:,.0f}\".replace(\",\", \"X\").replace(\".\", \",\").replace(\"X\", \\".\\")\n", "\n", "def pct_fmt(x):\n", "    if pd.isna(x):\n", "        return \"-\"\n", "    return f\"{x*100:.2f}%\"\n", "\n", "def style_plotly(fig, title=None, height=500):\n", "    fig.update_layout(\n", "        template=\"plotly_white\",\n", "        title=title,\n", "        legend_title_text=\"\",\n", "        hovermode=\"x unified\",\n", "        margin=dict(l=40, r=40, t=60, b=40),\n", "        height=height,\n", "    )\n", "    return fig\n", "\n", "def set_try_axis(fig, axis=\"y\"):\n", "    if axis == \"y\":\n", "        fig.update_yaxes(tickprefix=\"\u20ba\", separatethousands=True)\n", "    elif axis == \"x\":\n", "        fig.update_xaxes(tickprefix=\"\u20ba\", separatethousands=True)\n", "    return fig\n", "\n", "def clean_weights(weights_dict, tickers):\n", "    w = pd.Series(weights_dict).reindex(tickers).fillna(0.0).astype(float)\n", "    if w.sum() <= 0:\n", "        w[:] = 1 / len(w)\n", "    return w / w.sum()\n", "\n", "def apply_gold_band(weights, gold_label, gold_min, gold_max):\n", "    w = weights.copy().astype(float)\n", "    if gold_label not in w.index:\n", "        return w / w.sum()\n", "\n", "    gold_w = float(w[gold_label])\n", "    target_gold = min(max(gold_w, gold_min), gold_max)\n", "\n", "    if abs(target_gold - gold_w) < 1e-12:\n", "        return w / w.sum()\n", "\n", "    others = w.drop(gold_label)\n", "    if others.sum() <= 0:\n", "        w[:] = 0.0\n", "        w[gold_label] = 1.0\n", "        return w\n", "\n", "    others = others / others.sum()\n", "    w[gold_label] = target_gold\n", "    w.loc[others.index] = (1 - target_gold) * others\n", "    return w / w.sum()\n", "\n", "def get_rule_based_views(price_window):\n", "    rets = price_window.pct_change().dropna()\n", "    ann_ret = rets.mean() * 252\n", "    vol = rets.std() * np.sqrt(252)\n", "    score = (ann_ret / vol.replace(0, np.nan)).replace([np.inf, -np.inf], np.nan).fillna(0.0)\n", "    views = score.clip(-0.15, 0.15)\n", "    confidences = (score.abs() / (score.abs().max() + 1e-9)).clip(0.20, 0.80)\n", "    return views.to_dict(), confidences.to_dict()"]}, {"cell_type": "code", "execution_count": null, "id": "57fa860c", "metadata": {}, "outputs": [], "source": ["def download_one_ticker(ticker, period=\"10y\"):\n", "    data = yf.download(ticker, period=period, auto_adjust=True, progress=False)\n", "    if data is None or len(data) == 0:\n", "        return None\n", "    if isinstance(data.columns, pd.MultiIndex):\n", "        if (\"Close\", ticker) in data.columns:\n", "            s = data[(\"Close\", ticker)].copy()\n", "        else:\n", "            s = data[\"Close\"].copy()\n", "    else:\n", "        s = data[\"Close\"].copy()\n", "    s = pd.Series(s).dropna()\n", "    s.name = ticker\n", "    return s\n", "\n", "series_list = []\n", "coverage_rows = []\n", "\n", "for ticker in CONFIG[\"tickers\"]:\n", "    s = download_one_ticker(ticker, period=CONFIG[\"download_period\"])\n", "    n = 0 if s is None else len(s)\n", "    start = None if s is None or len(s) == 0 else str(s.index.min().date())\n", "    end = None if s is None or len(s) == 0 else str(s.index.max().date())\n", "    coverage_rows.append({\n", "        \"Ticker\": ticker,\n", "        \"Etiket\": CONFIG[\"ticker_labels\"].get(ticker, ticker),\n", "        \"G\u00f6zlem Say\u0131s\u0131\": n,\n", "        \"\u0130lk Tarih\": start,\n", "        \"Son Tarih\": end,\n", "        \"Durum\": \"OK\" if n > 0 else \"Veri Yok\",\n", "    })\n", "    if s is not None and len(s) > 0:\n", "        s.name = CONFIG[\"ticker_labels\"].get(ticker, ticker)\n", "        series_list.append(s)\n", "\n", "coverage = pd.DataFrame(coverage_rows)\n", "display(coverage)\n", "\n", "if len(series_list) == 0:\n", "    raise ValueError(\"Hi\u00e7bir ticker i\u00e7in veri indirilemedi.\")\n", "\n", "prices = pd.concat(series_list, axis=1).sort_index()\n", "prices = prices.ffill()\n", "\n", "# \u00c7ok eksik kolonlar\u0131 at\n", "min_non_null = int(len(prices) * 0.60)\n", "keep_cols = [c for c in prices.columns if prices[c].notna().sum() >= min_non_null]\n", "prices = prices[keep_cols]\n", "\n", "# Kesi\u015fim yerine daha dayan\u0131kl\u0131 \u015fekilde ge\u00e7 d\u00f6nemden ba\u015flat\n", "first_valid_dates = prices.apply(lambda s: s.first_valid_index())\n", "common_start = first_valid_dates.max()\n", "prices = prices.loc[common_start:].dropna()\n", "\n", "if prices.shape[1] < CONFIG[\"min_assets_required\"]:\n", "    raise ValueError(f\"Yeterli aktif varl\u0131k yok. Kalan varl\u0131k say\u0131s\u0131: {prices.shape[1]}\")\n", "\n", "available_days = len(prices)\n", "effective_lookback_days = min(CONFIG[\"target_lookback_days\"], max(60, available_days - 40))\n", "\n", "monthly_points = prices.resample(\"MS\").first().dropna()\n", "if len(monthly_points) < 4:\n", "    raise ValueError(\"Ayl\u0131k test i\u00e7in yeterli veri yok.\")\n", "\n", "effective_test_months = min(CONFIG[\"target_test_months\"], max(3, len(monthly_points) - 1))\n", "\n", "print(\"Kullan\u0131lan varl\u0131klar:\", list(prices.columns))\n", "print(\"Toplam g\u00fcnl\u00fck g\u00f6zlem:\", len(prices))\n", "print(\"Efektif lookback_days:\", effective_lookback_days)\n", "print(\"Efektif test_months:\", effective_test_months)\n", "\n", "display(prices.tail())"]}, {"cell_type": "markdown", "id": "07e91a88", "metadata": {}, "source": ["## Normalize Fiyatlar\n", "\n", "B\u00fct\u00fcn varl\u0131klar 100'den ba\u015flat\u0131l\u0131r. B\u00f6ylece fiyat d\u00fczeyi de\u011fil, performans fark\u0131 g\u00f6r\u00fcl\u00fcr."]}, {"cell_type": "code", "execution_count": null, "id": "4f93f8f7", "metadata": {}, "outputs": [], "source": ["norm_prices = prices / prices.iloc[0] * 100\n", "fig = px.line(\n", "    norm_prices,\n", "    x=norm_prices.index,\n", "    y=norm_prices.columns,\n", "    labels={\"value\": \"Ba\u015flang\u0131\u00e7=100\", \"index\": \"Tarih\"},\n", ")\n", "fig = style_plotly(fig, \"Normalize Fiyat Kar\u015f\u0131la\u015ft\u0131rmas\u0131\")\n", "fig.show()"]}, {"cell_type": "markdown", "id": "cd621c4b", "metadata": {}, "source": ["## Korelasyon Haritas\u0131\n", "\n", "Birbirine benzeyen varl\u0131klar\u0131 ay\u0131rt etmek i\u00e7in."]}, {"cell_type": "code", "execution_count": null, "id": "75d7151c", "metadata": {}, "outputs": [], "source": ["rets = prices.pct_change().dropna()\n", "corr = rets.corr()\n", "fig = px.imshow(\n", "    corr,\n", "    text_auto=True,\n", "    aspect=\"auto\",\n", "    color_continuous_scale=\"RdBu_r\",\n", "    zmin=-1,\n", "    zmax=1,\n", ")\n", "fig = style_plotly(fig, \"Getiri Korelasyonlar\u0131\")\n", "fig.show()"]}, {"cell_type": "code", "execution_count": null, "id": "dedfdc1e", "metadata": {}, "outputs": [], "source": ["def get_equal_weight(asset_names):\n", "    return pd.Series(1 / len(asset_names), index=asset_names)\n", "\n", "def get_hrp_weights(price_window):\n", "    ret_window = price_window.pct_change().dropna()\n", "    hrp = HRPOpt(ret_window)\n", "    weights = hrp.optimize()\n", "    return clean_weights(weights, price_window.columns)\n", "\n", "def get_bl_weights(price_window):\n", "    S = CovarianceShrinkage(price_window).ledoit_wolf()\n", "    views, confidences = get_rule_based_views(price_window)\n", "\n", "    bl = BlackLittermanModel(\n", "        S,\n", "        pi=\"equal\",\n", "        absolute_views=views,\n", "        omega=\"default\",\n", "    )\n", "    posterior_rets = bl.bl_returns()\n", "\n", "    ef = EfficientFrontier(posterior_rets, S, weight_bounds=(0, CONFIG[\"max_weight\"]))\n", "    ef.max_sharpe(risk_free_rate=CONFIG[\"risk_free_rate\"])\n", "    weights = ef.clean_weights()\n", "\n", "    weights = clean_weights(weights, price_window.columns)\n", "    weights = apply_gold_band(\n", "        weights,\n", "        CONFIG[\"gold_label\"],\n", "        CONFIG[\"gold_min\"],\n", "        CONFIG[\"gold_max\"],\n", "    )\n", "\n", "    diagnostics = pd.DataFrame({\n", "        \"view\": pd.Series(views),\n", "        \"confidence\": pd.Series(confidences),\n", "    })\n", "    return weights, diagnostics\n", "\n", "def run_salary_backtest(prices, strategy_name):\n", "    monthly_prices = prices.resample(\"MS\").first().dropna()\n", "    start_idx = len(monthly_prices) - effective_test_months\n", "    if start_idx <= 0:\n", "        raise ValueError(\"Test i\u00e7in yeterli ayl\u0131k veri yok.\")\n", "\n", "    capital_cash = 0.0\n", "    shares = pd.Series(0.0, index=prices.columns)\n", "    history = []\n", "    rebalance_rows = []\n", "    bl_diag_rows = []\n", "\n", "    rebalance_dates = monthly_prices.index[start_idx:]\n", "\n", "    for i, dt in enumerate(rebalance_dates):\n", "        capital_cash += CONFIG[\"salary_amount_try\"]\n", "        price_window = prices.loc[:dt].tail(effective_lookback_days)\n", "\n", "        if len(price_window) < 40:\n", "            continue\n", "\n", "        if strategy_name == \"E\u015fit A\u011f\u0131rl\u0131k\":\n", "            weights = get_equal_weight(prices.columns)\n", "            diagnostics = None\n", "        elif strategy_name == \"HRP\":\n", "            weights = get_hrp_weights(price_window)\n", "            diagnostics = None\n", "        elif strategy_name == \"Black-Litterman\":\n", "            weights, diagnostics = get_bl_weights(price_window)\n", "        else:\n", "            raise ValueError(\"Bilinmeyen strateji\")\n", "\n", "        current_prices = prices.loc[dt]\n", "        existing_value = float((shares * current_prices).sum())\n", "        total_value = existing_value + capital_cash\n", "\n", "        target_values = weights * total_value\n", "        shares = target_values / current_prices\n", "        capital_cash = 0.0\n", "\n", "        next_dt = rebalance_dates[i + 1] if i + 1 < len(rebalance_dates) else prices.index[-1]\n", "        path = prices.loc[(prices.index >= dt) & (prices.index <= next_dt)]\n", "        values = path.mul(shares, axis=1).sum(axis=1)\n", "\n", "        for t, v in values.items():\n", "            history.append({\n", "                \"date\": t,\n", "                \"strategy\": strategy_name,\n", "                \"portfolio_value\": float(v),\n", "            })\n", "\n", "        row = {\n", "            \"date\": dt,\n", "            \"strategy\": strategy_name,\n", "            \"capital_after_contribution\": total_value,\n", "        }\n", "        for c, w in weights.items():\n", "            row[f\"weight_{c}\"] = float(w)\n", "        rebalance_rows.append(row)\n", "\n", "        if diagnostics is not None:\n", "            tmp = diagnostics.copy()\n", "            tmp[\"date\"] = dt\n", "            tmp[\"strategy\"] = strategy_name\n", "            tmp = tmp.reset_index().rename(columns={\"index\": \"asset\"})\n", "            bl_diag_rows.append(tmp)\n", "\n", "    hist_df = pd.DataFrame(history).drop_duplicates([\"date\", \"strategy\"])\n", "    weights_df = pd.DataFrame(rebalance_rows)\n", "    bl_diag_df = pd.concat(bl_diag_rows, ignore_index=True) if bl_diag_rows else pd.DataFrame()\n", "    return hist_df, weights_df, bl_diag_df"]}, {"cell_type": "markdown", "id": "4d77aa09", "metadata": {}, "source": ["## Pseudo-Live Maa\u015f Testi\n", "\n", "Her ay ba\u015f\u0131nda sabit maa\u015f katk\u0131s\u0131 eklenir ve yaln\u0131zca o tarihe kadar g\u00f6r\u00fclen veriyle a\u011f\u0131rl\u0131klar belirlenir."]}, {"cell_type": "code", "execution_count": null, "id": "e4696c19", "metadata": {}, "outputs": [], "source": ["strategies = [\"E\u015fit A\u011f\u0131rl\u0131k\", \"HRP\", \"Black-Litterman\"]\n", "\n", "hist_parts = []\n", "weight_parts = []\n", "diag_parts = []\n", "\n", "for s in strategies:\n", "    h, w, d = run_salary_backtest(prices, s)\n", "    hist_parts.append(h)\n", "    weight_parts.append(w)\n", "    if not d.empty:\n", "        diag_parts.append(d)\n", "\n", "hist_df = pd.concat(hist_parts, ignore_index=True)\n", "weights_df = pd.concat(weight_parts, ignore_index=True)\n", "bl_diag_df = pd.concat(diag_parts, ignore_index=True) if diag_parts else pd.DataFrame()\n", "\n", "display(hist_df.tail())"]}, {"cell_type": "code", "execution_count": null, "id": "66f0511b", "metadata": {}, "outputs": [], "source": ["summary_rows = []\n", "contributed = CONFIG[\"salary_amount_try\"] * effective_test_months\n", "\n", "for s in strategies:\n", "    sub = hist_df[hist_df[\"strategy\"] == s].sort_values(\"date\").copy()\n", "    sub[\"ret\"] = sub[\"portfolio_value\"].pct_change().fillna(0.0)\n", "\n", "    ending_value = float(sub[\"portfolio_value\"].iloc[-1])\n", "    net_profit = ending_value - contributed\n", "    ann_vol = float(sub[\"ret\"].std() * np.sqrt(252))\n", "    sharpe = float((sub[\"ret\"].mean() / (sub[\"ret\"].std() + 1e-9)) * np.sqrt(252))\n", "    drawdown = sub[\"portfolio_value\"] / sub[\"portfolio_value\"].cummax() - 1\n", "    maxdd = float(drawdown.min())\n", "    twr = float(ending_value / contributed - 1)\n", "\n", "    summary_rows.append({\n", "        \"Strateji\": s,\n", "        \"Toplam Yat\u0131r\u0131lan\": contributed,\n", "        \"Biti\u015f De\u011feri\": ending_value,\n", "        \"Net Kar\": net_profit,\n", "        \"TWR\": twr,\n", "        \"Y\u0131ll\u0131k Volatilite\": ann_vol,\n", "        \"Sharpe\": sharpe,\n", "        \"Maksimum D\u00fc\u015f\u00fc\u015f\": maxdd,\n", "    })\n", "\n", "summary = pd.DataFrame(summary_rows)\n", "summary_display = summary.copy()\n", "for c in [\"Toplam Yat\u0131r\u0131lan\", \"Biti\u015f De\u011feri\", \"Net Kar\"]:\n", "    summary_display[c] = summary_display[c].map(try_fmt)\n", "for c in [\"TWR\", \"Y\u0131ll\u0131k Volatilite\", \"Maksimum D\u00fc\u015f\u00fc\u015f\"]:\n", "    summary_display[c] = summary_display[c].map(pct_fmt)\n", "summary_display[\"Sharpe\"] = summary_display[\"Sharpe\"].map(lambda x: f\"{x:.2f}\")\n", "display(summary_display)"]}, {"cell_type": "markdown", "id": "9cedfc9d", "metadata": {}, "source": ["## Portf\u00f6y De\u011feri Grafi\u011fi"]}, {"cell_type": "code", "execution_count": null, "id": "c87880cf", "metadata": {}, "outputs": [], "source": ["fig = px.line(\n", "    hist_df,\n", "    x=\"date\",\n", "    y=\"portfolio_value\",\n", "    color=\"strategy\",\n", "    labels={\"portfolio_value\": \"Portf\u00f6y De\u011feri\", \"date\": \"Tarih\", \"strategy\": \"Strateji\"},\n", ")\n", "fig = style_plotly(fig, \"Stratejilere G\u00f6re Portf\u00f6y De\u011feri\")\n", "fig = set_try_axis(fig, \"y\")\n", "fig.show()"]}, {"cell_type": "markdown", "id": "3bdfcb96", "metadata": {}, "source": ["## Drawdown Grafi\u011fi"]}, {"cell_type": "code", "execution_count": null, "id": "3bd511c3", "metadata": {}, "outputs": [], "source": ["dd_parts = []\n", "for s in strategies:\n", "    sub = hist_df[hist_df[\"strategy\"] == s].sort_values(\"date\").copy()\n", "    sub[\"drawdown\"] = sub[\"portfolio_value\"] / sub[\"portfolio_value\"].cummax() - 1\n", "    dd_parts.append(sub[[\"date\", \"strategy\", \"drawdown\"]])\n", "\n", "dd_df = pd.concat(dd_parts, ignore_index=True)\n", "\n", "fig = px.line(\n", "    dd_df,\n", "    x=\"date\",\n", "    y=\"drawdown\",\n", "    color=\"strategy\",\n", "    labels={\"drawdown\": \"Drawdown\", \"date\": \"Tarih\", \"strategy\": \"Strateji\"},\n", ")\n", "fig = style_plotly(fig, \"Stratejilere G\u00f6re Drawdown\")\n", "fig.update_yaxes(tickformat=\".0%\")\n", "fig.show()"]}, {"cell_type": "markdown", "id": "f0dc5d5d", "metadata": {}, "source": ["## Son A\u011f\u0131rl\u0131klar"]}, {"cell_type": "code", "execution_count": null, "id": "8079e8e1", "metadata": {}, "outputs": [], "source": ["last_weights = weights_df.sort_values(\"date\").groupby(\"strategy\").tail(1).copy()\n", "weight_cols = [c for c in last_weights.columns if c.startswith(\"weight_\")]\n", "pretty_last_weights = last_weights[[\"strategy\"] + weight_cols].copy()\n", "pretty_last_weights.columns = [\"Strateji\"] + [c.replace(\"weight_\", \"\") for c in weight_cols]\n", "\n", "for c in pretty_last_weights.columns[1:]:\n", "    pretty_last_weights[c] = pretty_last_weights[c].map(pct_fmt)\n", "\n", "display(pretty_last_weights.reset_index(drop=True))"]}, {"cell_type": "markdown", "id": "7a980d86", "metadata": {}, "source": ["## Yeniden Dengeleme \u00d6zeti"]}, {"cell_type": "code", "execution_count": null, "id": "19d9084d", "metadata": {}, "outputs": [], "source": ["rebalance_summary = weights_df.copy()\n", "rebalance_summary[\"capital_after_contribution\"] = rebalance_summary[\"capital_after_contribution\"].map(try_fmt)\n", "for c in [col for col in rebalance_summary.columns if col.startswith(\"weight_\")]:\n", "    rebalance_summary[c] = rebalance_summary[c].map(pct_fmt)\n", "\n", "display(rebalance_summary.head(30))"]}, {"cell_type": "markdown", "id": "38754c34", "metadata": {}, "source": ["## Black-Litterman View Tan\u0131lar\u0131\n", "\n", "Bu b\u00f6l\u00fcm Black-Litterman stratejisinin kulland\u0131\u011f\u0131 basit kural tabanl\u0131 g\u00f6r\u00fc\u015fleri g\u00f6sterir."]}, {"cell_type": "code", "execution_count": null, "id": "0cb6a712", "metadata": {}, "outputs": [], "source": ["if bl_diag_df.empty:\n", "    print(\"BL tan\u0131 tablosu bo\u015f.\")\n", "else:\n", "    diag_show = bl_diag_df.copy()\n", "    diag_show[\"view\"] = diag_show[\"view\"].map(pct_fmt)\n", "    diag_show[\"confidence\"] = diag_show[\"confidence\"].map(lambda x: f\"{x:.2f}\")\n", "    display(diag_show.head(50))"]}], "metadata": {"kernelspec": {"display_name": "Python 3", "language": "python", "name": "python3"}, "language_info": {"name": "python", "version": "3.11"}}, "nbformat": 4, "nbformat_minor": 5}